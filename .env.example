# AI Agent Security Shield - Environment Variables
# Copy this to .env and fill in your values

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ChromaDB
CHROMA_PERSIST_DIR=./data/chromadb

# Logging
LOG_LEVEL=INFO

# Guardian Commander Settings
THREAT_ALERT_EMAIL=your_email@example.com

# Dashboard
DASHBOARD_PORT=3000
API_PORT=8000
